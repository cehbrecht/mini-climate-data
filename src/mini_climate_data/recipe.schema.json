{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/macpingu/mini-climate-data/recipe.schema.json",
  "title": "mini-climate-data recipe",
  "type": "object",
  "required": ["name", "source", "reducer", "artifacts", "validation"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_/-]*$"
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": ["kind", "provenance"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["synthetic", "direct_url", "intake", "stac"]
        },
        "provenance": { "type": "string" },
        "license": { "type": "string" },
        "citation": { "type": "string" },
        "url": { "type": "string" },
        "catalog_url": { "type": "string" },
        "entry": { "type": "string" },
        "ds_id": { "type": "string" },
        "ds_id_column": {
          "type": "string",
          "default": "ds_id"
        },
        "url_column": {
          "type": "string",
          "default": "url"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "intake_kwargs": {
          "type": "object",
          "additionalProperties": true
        },
        "collection": { "type": "string" },
        "item_id": { "type": "string" },
        "asset": { "type": "string" },
        "query": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "direct_url" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["url"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "intake" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["catalog_url", "entry"]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "stac" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["catalog_url"]
          }
        }
      ]
    },
    "reducer": {
      "type": "object",
      "required": ["script"],
      "additionalProperties": false,
      "properties": {
        "script": { "type": "string" },
        "function": { "type": "string" },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "logical_name", "max_size"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "logical_name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_./-]*$"
          },
          "max_size": {
            "type": "integer",
            "minimum": 1
          },
          "checksum": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["openable"],
      "additionalProperties": false,
      "properties": {
        "openable": {
          "type": "boolean"
        },
        "engine": {
          "type": "string",
          "enum": ["bytes", "netcdf", "zarr"]
        },
        "required_variables": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
